# Copie este arquivo para .env e ajuste se quiser.

# Banco de dados.
# Padrao: SQLite (nao precisa instalar nada).
DATABASE_URL=sqlite:///./raizes.db
# Para usar PostgreSQL, descomente e ajuste:
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/raizes

# Chave usada para assinar os tokens JWT. Troque por algo secreto em producao.
SECRET_KEY=troque-esta-chave-em-producao-1234567890

# Tempo de expiracao do token, em minutos.
ACCESS_TOKEN_EXPIRE_MINUTES=60
